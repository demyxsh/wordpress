#!/bin/bash
# Demyx
# https://demyx.sh
set -eEuo pipefail
#
#	Main.
#
demyx_sudo() {
	local DEMYX_SUDO="${1:-}"

	case "$DEMYX_SUDO" in
		cron)
			demyx_sudo_cron
		;;
		php)
			demyx_sudo_php
		;;
		*)
			# Execute all sudo functions
			demyx_sudo_cron
			demyx_sudo_php
		;;
	esac
}
#
#	Cron.
#
demyx_sudo_cron() {
	local DEMYX_SUDO_CRON=
	local DEMYX_CRON_WP_INTERVAL_SAFE="${DEMYX_CRON_WP_INTERVAL:-*/5 * * * *}"
	local DEMYX_CRON_DEMYX_SAFE="${DEMYX:-/demyx}"
	local DEMYX_CRON_CONFIG_SAFE="${DEMYX_CONFIG:-/etc/demyx}"
	local DEMYX_CRON_LOG_SAFE="${DEMYX_LOG:-/var/log/demyx}"
	local DEMYX_CRON_DOMAIN_SAFE="${DEMYX_DOMAIN:-domain.tld}"
	local DEMYX_CRON_BEDROCK_SAFE="${DEMYX_BEDROCK:-false}"
	DEMYX_SUDO_CRON="$(pgrep crond || true)"

	{
		# Cron runs with a minimal environment; define what demyx-cron needs.
		echo "SHELL=/bin/sh"
		echo "PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
		echo "DEMYX=${DEMYX_CRON_DEMYX_SAFE}"
		echo "DEMYX_CONFIG=${DEMYX_CRON_CONFIG_SAFE}"
		echo "DEMYX_LOG=${DEMYX_CRON_LOG_SAFE}"
		echo "DEMYX_DOMAIN=${DEMYX_CRON_DOMAIN_SAFE}"
		echo "DEMYX_BEDROCK=${DEMYX_CRON_BEDROCK_SAFE}"
		echo

		# WP cron
		echo "${DEMYX_CRON_WP_INTERVAL_SAFE} /usr/local/bin/demyx-cron wp"

		# ACL
		echo "0 0 * * * /usr/bin/sudo -E /usr/local/bin/demyx-cron acl"

		# User defined cron
		if [[ -f "$DEMYX_CONFIG"/custom/cron ]]; then
			cat < "$DEMYX_CONFIG"/custom/cron
		fi
	} | sed 's|"||g' > /etc/crontab

	crontab -u demyx /etc/crontab

	if [[ "$DEMYX_CRON" = true && -z "$DEMYX_SUDO_CRON" ]]; then
		crond
	fi
}
#
#	PHP.
#
demyx_sudo_php() {
		case "$DEMYX_PHP" in
        ""|8.4|84)
            DEMYX_PHP=84
        ;;
        8.3|83)
            DEMYX_PHP=83
        ;;
        *)
            DEMYX_PHP=83
        ;;
    esac

	ln -sf /usr/bin/php"${DEMYX_PHP}" /usr/bin/php
	ln -sf /usr/sbin/php-fpm"${DEMYX_PHP}" /usr/sbin/php-fpm

    # Alpine php-fpm package defaults to /var/log/php83/error.log in php-fpm.conf.
    # Ensure that path is writable for non-root startup to prevent FPM init failure.
    mkdir -p /var/log/php83
    touch /var/log/php83/error.log
    chown -R demyx:demyx /var/log/php83
}
#
#	Init.
#
demyx_sudo "$@"
